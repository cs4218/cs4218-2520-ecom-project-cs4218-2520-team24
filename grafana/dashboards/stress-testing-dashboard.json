{
    "id": null,
    "title": "E-commerce Stress Testing Dashboard - Full Optimized",
    "tags": ["stress-testing", "performance"],
    "timezone": "browser",
    "panels": [
        {
            "id": 6,
            "title": "Peak Performance Summary (Max RPS)",
            "type": "stat",
            "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "targets": [
                {
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "max_over_time(sum(rate(http_requests_total{job=\"app\"}[1m]))[30m:])",
                    "legendFormat": "Max RPS Achieved",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": { "mode": "thresholds" },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            { "color": "green", "value": null },
                            { "color": "red", "value": 800 }
                        ]
                    },
                    "unit": "reqps"
                }
            }
        },
        {
            "id": 1,
            "title": "1. The Elbow Curve - RPS & P95 Latency",
            "type": "timeseries",
            "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "targets": [
                {
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "sum(rate(http_requests_total{job=\"app\"}[1m]))",
                    "legendFormat": "RPS",
                    "refId": "A"
                },
                {
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"app\"}[1m])))",
                    "legendFormat": "P95 Latency (s)",
                    "refId": "B"
                }
            ],
            "fieldConfig": {
                "defaults": {},
                "overrides": [
                    {
                        "matcher": { "id": "byName", "options": "RPS" },
                        "properties": [
                            { "id": "custom.axisPlacement", "value": "left" },
                            { "id": "unit", "value": "reqps" },
                            { "id": "custom.axisLabel", "value": "Requests/sec" },
                            { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
                        ]
                    },
                    {
                        "matcher": { "id": "byName", "options": "P95 Latency (s)" },
                        "properties": [
                            { "id": "custom.axisPlacement", "value": "right" },
                            { "id": "unit", "value": "s" },
                            { "id": "custom.axisLabel", "value": "Latency (seconds)" },
                            { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
                        ]
                    }
                ]
            }
        },
        {
            "id": 2,
            "title": "2. Resource Saturation - CPU & Memory",
            "type": "timeseries",
            "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "targets": [
                {
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "100 * sum(rate(container_cpu_usage_seconds_total{name=\"ecom-app\"}[1m])) / scalar(max(container_spec_cpu_quota{name=\"ecom-app\"}) / max(container_spec_cpu_period{name=\"ecom-app\"}))",
                    "legendFormat": "CPU Usage %",
                    "refId": "A"
                },
                {
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "100 * (container_memory_working_set_bytes{name=\"ecom-app\"} / container_spec_memory_limit_bytes{name=\"ecom-app\"})",
                    "legendFormat": "Memory Usage %",
                    "refId": "B"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "percent",
                    "min": 0,
                    "max": 100
                }
            }
        },
        {
            "id": 3,
            "title": "3. Node.js Internal Health",
            "type": "timeseries",
            "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "targets": [
                {
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "nodejs_nodejs_eventloop_lag_seconds{job=\"app\"}",
                    "legendFormat": "Event Loop Lag",
                    "refId": "A"
                },
                {
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "sum(rate(nodejs_nodejs_gc_duration_seconds_sum{job=\"app\"}[1m]))",
                    "legendFormat": "GC Pressure",
                    "refId": "B"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "s"
                }
            }
        },
        {
            "id": 11,
            "title": "4. Event Loop Lag Percentiles",
            "type": "timeseries",
            "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "targets": [
                {
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "nodejs_nodejs_eventloop_lag_mean_seconds{job=\"app\"}",
                    "legendFormat": "Mean",
                    "refId": "A"
                },
                {
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "nodejs_nodejs_eventloop_lag_p50_seconds{job=\"app\"}",
                    "legendFormat": "P50",
                    "refId": "B"
                },
                {
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "nodejs_nodejs_eventloop_lag_p90_seconds{job=\"app\"}",
                    "legendFormat": "P90",
                    "refId": "C"
                },
                {
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "nodejs_nodejs_eventloop_lag_p99_seconds{job=\"app\"}",
                    "legendFormat": "P99",
                    "refId": "D"
                },
                {
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "nodejs_nodejs_eventloop_lag_max_seconds{job=\"app\"}",
                    "legendFormat": "Max",
                    "refId": "E"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "s",
                    "min": 0
                }
            },
            "options": {
                "tooltip": { "mode": "multi", "sort": "desc" }
            }
        },
        {
            "id": 5,
            "title": "5. Failure Modes - 5xx Errors by Endpoint",
            "type": "timeseries",
            "gridPos": { "h": 8, "w": 24, "x": 0, "y": 36 },
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "targets": [
                {
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "sum by (path) (rate(http_requests_total{job=\"app\", status_code=~\"5..\"}[1m])) or vector(0)",
                    "legendFormat": "{{path}}",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps",
                    "custom": {
                        "stacking": { "mode": "normal" },
                        "fillOpacity": 30
                    }
                }
            },
            "options": {
                "tooltip": { "mode": "multi", "sort": "desc" }
            }
        },
        {
            "id": 7,
            "title": "6. Error Rate % by Endpoint",
            "type": "timeseries",
            "gridPos": { "h": 8, "w": 24, "x": 0, "y": 44 },
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "targets": [
                {
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "100 * sum(rate(http_requests_total{job=\"app\", status_code=~\"5..\"}[1m])) / sum(rate(http_requests_total{job=\"app\"}[1m])) or vector(0)",
                    "legendFormat": "Overall Error Rate %",
                    "refId": "A"
                },
                {
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "sum(rate(http_requests_total{job=\"app\", status_code=~\"5..\"}[1m])) or vector(0)",
                    "legendFormat": "Total 5xx Errors/sec",
                    "refId": "B"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "percent",
                    "min": 0,
                    "max": 100
                },
                "overrides": [
                    {
                        "matcher": { "id": "byName", "options": "Total 5xx Errors/sec" },
                        "properties": [
                            { "id": "unit", "value": "reqps" },
                            { "id": "custom.axisPlacement", "value": "right" }
                        ]
                    }
                ]
            },
            "options": {
                "tooltip": { "mode": "multi", "sort": "desc" }
            }
        },
        {
            "id": 8,
            "title": "7. MongoDB Resource Usage",
            "type": "timeseries",
            "gridPos": { "h": 8, "w": 24, "x": 0, "y": 52 },
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "targets": [
                {
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "100 * sum(rate(container_cpu_usage_seconds_total{name=\"cs4218-2520-ecom-project-cs4218-2520-team24_mongodb_1\"}[1m])) / scalar(max(container_spec_cpu_quota{name=\"cs4218-2520-ecom-project-cs4218-2520-team24_mongodb_1\"}) / max(container_spec_cpu_period{name=\"cs4218-2520-ecom-project-cs4218-2520-team24_mongodb_1\"}))",
                    "legendFormat": "MongoDB CPU %",
                    "refId": "A"
                },
                {
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "100 * (container_memory_working_set_bytes{name=\"cs4218-2520-ecom-project-cs4218-2520-team24_mongodb_1\"} / container_spec_memory_limit_bytes{name=\"cs4218-2520-ecom-project-cs4218-2520-team24_mongodb_1\"})",
                    "legendFormat": "MongoDB Memory %",
                    "refId": "B"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "percent",
                    "min": 0,
                    "max": 100
                }
            }
        },
        {
            "id": 9,
            "title": "8. MongoDB Performance Metrics",
            "type": "timeseries",
            "gridPos": { "h": 8, "w": 24, "x": 0, "y": 60 },
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "targets": [
                {
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "sum by (type) (rate(mongodb_op_counters_total[1m]))",
                    "legendFormat": "{{type}} Operations/sec",
                    "refId": "A"
                },
                {
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "mongodb_mongod_wiredtiger_cache_bytes{type=\"total\"} / 1024 / 1024",
                    "legendFormat": "WiredTiger Cache Used (MB)",
                    "refId": "B"
                },
                {
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "mongodb_connections{state=\"current\"}",
                    "legendFormat": "Active Connections",
                    "refId": "C"
                }
            ]
        },
        {
            "id": 10,
            "title": "9. MongoDB Active Connections",
            "type": "timeseries",
            "gridPos": { "h": 8, "w": 24, "x": 0, "y": 68 },
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "targets": [
                {
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "mongodb_ss_connections{conn_type=\"current\"}",
                    "legendFormat": "Active Connections (current)",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "min": 0,
                    "custom": {
                        "fillOpacity": 15
                    },
                    "color": { "mode": "fixed", "fixedColor": "orange" }
                }
            },
            "options": {
                "tooltip": { "mode": "single" }
            }
        }
    ],
    "schemaVersion": 36,
    "version": 4
}
