{
  "name": "ecom",
  "version": "1.0.0",
  "description": "ecommerce rest api",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "nodemon server.js",
    "client": "npm start --prefix ./client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "lint:security": "eslint server.js controllers/**/*.js routes/**/*.js models/**/*.js middlewares/**/*.js helpers/**/*.js config/**/*.js --ignore-pattern '**/*.test.js' --ignore-pattern 'tests/**' --ignore-pattern 'coverage/**'",
    "lint:security:all": "npm run lint:security && npm run lint:security --prefix client",
    "sonarqube": "sonar-scanner",
    "test": "npm run test:backend && npm run test:frontend",
    "test:frontend": "NODE_OPTIONS=--no-warnings jest --config jest.frontend.config.js",
    "test:backend": "NODE_OPTIONS=--no-warnings jest --config jest.backend.config.js"
  },
  "keywords": [],
  "author": "RP",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "braintree": "^3.22.0",
    "colors": "^1.4.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "date-fns": "^3.3.1",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-formidable": "^1.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.3.0",
    "mongoose": "^8.1.2",
    "morgan": "^1.10.0",
    "nodemon": "^3.0.3",
    "prom-client": "^15.1.3",
    "react-icons": "^5.6.0",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@babel/core": "^7.24.5",
    "@babel/plugin-transform-modules-commonjs": "^7.28.6",
    "@babel/preset-env": "^7.24.5",
    "@babel/preset-react": "^7.24.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.12.12",
    "babel-jest": "^29.7.0",
    "eslint": "^8.57.1",
    "eslint-plugin-security": "^3.0.1",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "mongodb-memory-server": "^11.0.1",
    "sonarqube-scanner": "^3.5.0",
    "supertest": "^7.2.2"
  }
}
